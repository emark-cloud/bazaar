# Bazaar frontend env. Copy to .env.local (gitignored) and fill in.
#
# Deployed Bazaar subgraph GraphQL endpoint (Ormi, Subgraph Studio, or a local
# graph-node, e.g. http://localhost:8000/subgraphs/name/bazaar). When unset, the
# UI reads everything from the chain directly (match history / P&L are hidden).
VITE_SUBGRAPH_URL=
