# Bazaar — environment template
# Copy to .env (gitignored) and fill in. .env is loaded by foundry via `--rpc-url $TESTNET_RPC` etc.

# === Networks (verified 2026-05-25; both candidates resolved chain 0xc488 / 50312) ===
TESTNET_RPC=https://api.infra.testnet.somnia.network
TESTNET_RPC_ALT=https://dream-rpc.somnia.network
TESTNET_CHAIN_ID=50312
TESTNET_EXPLORER=https://shannon-explorer.somnia.network

MAINNET_RPC=https://api.infra.mainnet.somnia.network
MAINNET_CHAIN_ID=5031
MAINNET_EXPLORER=https://explorer.somnia.network

# === Somnia agent platform ===
PLATFORM_TESTNET=0x037Bb9C718F3f7fe5eCBDB0b600D607b52706776
PLATFORM_MAINNET=0x5E5205CF39E766118C01636bED000A54D93163E6

# === Agent Explorer (UI) ===
EXPLORER_TESTNET=https://agents.testnet.somnia.network
EXPLORER_MAINNET=https://agents.somnia.network

# === Receipt services ===
RECEIPTS_TESTNET=https://receipts.testnet.agents.somnia.host
RECEIPTS_MAINNET=https://receipts.mainnet.agents.somnia.host

# === Chainlink VRF v2.5 (Protofire) ===
VRF_WRAPPER_TESTNET=0x763cC914d5CA79B04dC4787aC14CcAd780a16BD2
VRF_WRAPPER_MAINNET=0x606b2B36516AB7479D1445Ec14B6B39B44901bf8

# === Dev wallet (Phase 0 deployer) ===
# Generated 2026-05-25 via `cast wallet new`. Public address only here. Private key lives in .env (gitignored).
DEPLOYER_ADDRESS=0xEc8B1FA455fED5dEf70c0eDe85cfbFfF752F39cF
PRIVATE_KEY=
